---
const { user } = Astro.locals;

// Highlight the link matching the current page. Home matches exactly; the
// destination links match by prefix so /sessions/<id>/recommendations still
// highlights "Movie night".
const path = Astro.url.pathname;
const isActive = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
const linkClass = (href: string) =>
  isActive(href)
    ? "font-semibold text-white underline underline-offset-4"
    : "text-purple-300 transition-colors hover:text-purple-100 hover:underline";
const brandClass = `font-semibold text-white transition-colors hover:text-blue-100${
  path === "/" ? " underline underline-offset-4" : ""
}`;
---

<div
  class="mb-4 flex flex-wrap items-center justify-between gap-x-3 gap-y-2 rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-xs text-white/80 sm:px-4 sm:text-sm"
>
  <div class="flex items-center gap-3 sm:gap-4">
    <a href="/" class:list={brandClass}>MovieMate</a>
    {
      user && (
        <>
          <a href="/sessions" class:list={linkClass("/sessions")}>
            Movie night
          </a>
          <a href="/profiles" class:list={linkClass("/profiles")}>
            Taste core
          </a>
        </>
      )
    }
  </div>
  <div class="flex items-center gap-3">
    {
      user ? (
        <>
          <span class="hidden max-w-48 truncate text-blue-100/70 sm:inline lg:max-w-none">{user.email}</span>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
              Sign out
            </button>
          </form>
        </>
      ) : (
        <>
          <a href="/auth/signin" class:list={linkClass("/auth/signin")}>
            Sign in
          </a>
          <a href="/auth/signup" class:list={linkClass("/auth/signup")}>
            Sign up
          </a>
        </>
      )
    }
  </div>
</div>
