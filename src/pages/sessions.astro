---
import Layout from "@/layouts/Layout.astro";
import SessionForm from "@/components/sessions/SessionForm";
import { createClient } from "@/lib/supabase";
import { DEFAULT_INTENSITY, type Intensity } from "@/lib/session-options";

interface SessionRow {
  id: string;
  mood: string | null;
  preferred_genre_ids: number[];
  excluded_genre_ids: number[];
  runtime_limit_minutes: number | null;
  intensity: Intensity;
  note: string | null;
}

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

const error = Astro.url.searchParams.get("error");

// On error, the just-persisted session is the latest row — re-fill the form from
// it so tonight's mood / genres / runtime / note survive a failed run. This is
// input preservation, not a return of "edit mode": the session is still created
// invisibly and there is no manage-session affordance.
let errorSession: SessionRow | null = null;
if (error && supabase && user) {
  const { data } = await supabase
    .from("movie_night_sessions")
    .select("id, mood, preferred_genre_ids, excluded_genre_ids, runtime_limit_minutes, intensity, note")
    .order("created_at", { ascending: false })
    .limit(1)
    .maybeSingle();
  errorSession = data ?? null;
}

// Fresh one-shot (no error): seed tonight's genre pickers from the remembered
// taste core (FR-004). Page-level seed only — the session owns its own genre
// columns, so tonight never writes back to the core (only /profiles does).
let prefilledPreferred: number[] = [];
let prefilledExcluded: number[] = [];
let prefilledFromCore = false;
let noCore = false;
if (supabase && user && !errorSession) {
  const { data: coreData } = await supabase
    .from("viewer_profiles")
    .select("preferred_genre_ids, excluded_genre_ids")
    .maybeSingle();
  if (coreData) {
    // The Supabase client is untyped, so fields come back as `any`; coerce
    // through `unknown` into concrete id arrays before they reach the form.
    const coreRaw = coreData as Record<string, unknown>;
    prefilledPreferred = Array.isArray(coreRaw.preferred_genre_ids) ? coreRaw.preferred_genre_ids.map(Number) : [];
    prefilledExcluded = Array.isArray(coreRaw.excluded_genre_ids) ? coreRaw.excluded_genre_ids.map(Number) : [];
    // The core contributed a seed only when it actually carries genres.
    prefilledFromCore = prefilledPreferred.length > 0 || prefilledExcluded.length > 0;
  } else {
    noCore = true;
  }
}
---

<Layout title="Movie night">
  <div class="p-4">
    <div class="mx-auto max-w-2xl py-8">
      <h1 class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Movie night
      </h1>
      <p class="mb-8 text-sm text-blue-100/60">Set tonight's preferences and get three picks in one click.</p>

      <div class="rounded-2xl border border-white/10 bg-white/10 p-6 text-white backdrop-blur-xl">
        <SessionForm
          client:load
          mood={errorSession ? errorSession.mood : ""}
          preferredGenreIds={errorSession ? errorSession.preferred_genre_ids : prefilledPreferred}
          excludedGenreIds={errorSession ? errorSession.excluded_genre_ids : prefilledExcluded}
          runtimeLimitMinutes={errorSession ? errorSession.runtime_limit_minutes : null}
          intensity={errorSession ? errorSession.intensity : DEFAULT_INTENSITY}
          note={errorSession ? errorSession.note : ""}
          serverError={error}
          prefilledFromCore={prefilledFromCore}
        />
      </div>

      {
        noCore && (
          <p class="mt-4 text-sm text-blue-100/60">
            No taste core yet —{" "}
            <a href="/profiles" class="text-purple-300 hover:underline">
              set one
            </a>{" "}
            so future nights pre-fill automatically.
          </p>
        )
      }
    </div>
  </div>
</Layout>
