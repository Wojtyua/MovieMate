---
import Layout from "@/layouts/Layout.astro";
import ProfileForm from "@/components/profiles/ProfileForm";
import { createClient } from "@/lib/supabase";

interface CoreRow {
  preferred_genre_ids: number[];
  excluded_genre_ids: number[];
}

const { user } = Astro.locals;

const supabase = createClient(Astro.request.headers, Astro.cookies);
let core: CoreRow | null = null;
if (supabase && user) {
  const { data } = await supabase
    .from("viewer_profiles")
    .select("preferred_genre_ids, excluded_genre_ids")
    .maybeSingle();
  core = data ?? null;
}

const error = Astro.url.searchParams.get("error");
const justSaved = Astro.url.searchParams.has("saved");
---

<Layout title="Remembered taste core">
  <div class="p-4">
    <div class="mx-auto max-w-2xl py-8">
      <h1 class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Remembered taste core
      </h1>
      <p class="mb-8 text-sm text-blue-100/60">
        Your stable preferred and avoid genres. This remembered core feeds every movie-night recommendation.
      </p>

      <div class="rounded-2xl border border-white/10 bg-white/10 p-6 text-white backdrop-blur-xl">
        <ProfileForm
          client:load
          preferredGenreIds={core?.preferred_genre_ids ?? []}
          excludedGenreIds={core?.excluded_genre_ids ?? []}
          serverError={error}
          justSaved={justSaved}
        />
      </div>
    </div>
  </div>
</Layout>
