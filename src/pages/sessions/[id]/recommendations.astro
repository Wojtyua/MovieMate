---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import PicksGrid, { type Pick } from "@/components/sessions/PicksGrid";

type PickRow = Pick;

const { id } = Astro.params;
const { user } = Astro.locals;

const supabase = createClient(Astro.request.headers, Astro.cookies);
let picks: PickRow[] = [];
if (supabase && user && id) {
  // The most recent recommendation run for this session (RLS scopes to owner).
  const { data: runs } = await supabase
    .from("recommendations")
    .select("id")
    .eq("session_id", id)
    .order("created_at", { ascending: false })
    .limit(1);
  const runId = runs && runs.length > 0 ? String((runs[0] as Record<string, unknown>).id) : null;
  if (runId) {
    const { data: pickData } = await supabase
      .from("recommendation_picks")
      .select("role, tmdb_movie_id, title, poster_path, overview, genre_ids, release_date, vote_average")
      .eq("recommendation_id", runId);
    // Display order (ROLE_RANK) is applied inside PicksGrid.
    picks = pickData ?? [];
  }
}
---

<Layout title="Your recommendations">
  <div class="p-4">
    <div class="mx-auto max-w-5xl py-8">
      <div class="mb-6 flex items-center justify-between">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Tonight's picks
        </h1>
        <a href="/sessions" class="text-sm text-purple-300 hover:underline">← Back to session</a>
      </div>

      {
        picks.length === 0 ? (
          <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
            <p class="text-blue-100/80">No recommendations yet for this session.</p>
            <p class="mt-2 text-sm text-blue-100/60">
              Head back to{" "}
              <a href="/sessions" class="text-purple-300 hover:underline">
                your session
              </a>{" "}
              and click “Get recommendations” to generate three picks.
            </p>
          </div>
        ) : (
          <PicksGrid client:load picks={picks} />
        )
      }
    </div>
  </div>
</Layout>
